<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Self-host 经常使用局域网 HTTP；生产请用 HTTPS。允许所有明文流量仅用于调试/自托管场景。 -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
